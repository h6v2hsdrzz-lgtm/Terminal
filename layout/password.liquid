<!doctype html>
<html lang="{{ request.locale.iso_code }}" class="no-js">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="{{ settings.color_background }}">
  <link rel="icon" type="image/svg+xml" href="{{ 'favicon.svg' | asset_url }}">
  <title>{{ shop.name }}</title>
  <meta name="description" content="{{ shop.description | default: shop.name | escape }}">
  {% style %}
    {{ settings.font_body | font_face: font_display: 'swap' }}
    {{ settings.font_heading | font_face: font_display: 'swap' }}
  {% endstyle %}
  {{ content_for_header }}
  {% style %}
    body{margin:0;font-family:{{ settings.font_body.family }},{{ settings.font_body.fallback_families }};background:{{ settings.color_cool_wash }};color:{{ settings.color_text }};min-height:100vh;display:grid;place-items:center;padding:1.5rem;text-align:center;line-height:1.55}
    h1{font-family:{{ settings.font_heading.family }},{{ settings.font_heading.fallback_families }};font-weight:700;font-size:clamp(2rem,7vw,3rem);margin:0 0 .5rem}
    .pw{max-width:26rem}
    .pw__logo{width:56px;height:56px;margin:0 auto 1.25rem}
    .pw p{color:{{ settings.color_text }};opacity:.75;margin:0 0 1.5rem}
    form{display:flex;gap:.5rem;flex-wrap:wrap;justify-content:center}
    input[type=password]{flex:1;min-width:12rem;padding:.9rem 1rem;border-radius:999px;border:1.5px solid rgba(0,0,0,.15);background:#fff}
    button{background:{{ settings.color_cta }};color:{{ settings.color_cta_text }};border:0;border-radius:999px;padding:.9rem 1.5rem;font-weight:700;cursor:pointer}
    .pw__err{color:#b00020;margin-top:.75rem;font-size:.9rem}
  {% endstyle %}
</head>
<body>
  <div class="pw">
    <div class="pw__logo">{{ 'favicon.svg' | inline_asset_content }}</div>
    <h1>{{ shop.name }}</h1>
    <p>{{ shop.password_message | default: 'On peaufine la fraîcheur. Reviens très vite. 🐾' }}</p>
    {% form 'storefront_password' %}
      {%- if form.errors -%}
        <p class="pw__err">{{ form.errors.translated_fields.password | capitalize }} {{ form.errors.messages.password }}</p>
      {%- endif -%}
      <input type="password" name="password" placeholder="Mot de passe" aria-label="Mot de passe">
      <button type="submit">Entrer</button>
    {% endform %}
  </div>
  {{ content_for_layout }}
</body>
</html>
