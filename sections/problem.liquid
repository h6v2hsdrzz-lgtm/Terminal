<section class="section {% if section.settings.background == 'alt' %}section--alt{% elsif section.settings.background == 'cool' %}section--cool{% endif %} anchor-offset" id="probleme">
  <div class="container">
    <div class="editorial__grid {% if section.settings.image_side == 'left' %}editorial--reverse{% endif %}">
      <div class="editorial__media reveal">
        <div class="media-frame media-frame--tall">
          {% render 'image', image: section.settings.image, sizes: '(min-width:850px) 46vw, 92vw', alt: section.settings.image_alt, placeholder: 'lifestyle-1' %}
        </div>
      </div>
      <div class="editorial__body reveal reveal--d1">
        {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{% render 'icon', name: 'sun', size: 16 %}{{ section.settings.eyebrow }}</span>{%- endif -%}
        <h2>{{ section.settings.title }}</h2>
        <div class="rte">{{ section.settings.body }}</div>

        {%- if section.blocks.size > 0 -%}
          <ul class="editorial__list">
            {%- for block in section.blocks -%}
              <li {{ block.shopify_attributes }}>
                {% render 'icon', name: block.settings.icon, size: 24 %}
                <span>{{ block.settings.text }}</span>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Le problème",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Sur-titre", "default": "Le vrai sujet" },
    { "type": "text", "id": "title", "label": "Titre", "default": "Ton chien ne transpire pas. Il subit." },
    { "type": "richtext", "id": "body", "label": "Texte", "default": "<p>Nous, on transpire pour évacuer la chaleur. Ton chien, lui, n'a presque que le halètement — et ses coussinets. Alors dès que ça grimpe, il cherche le carrelage, se colle aux coins frais, tourne en rond pour trouver LE bon spot.</p><p>Un chien qui a trop chaud dort mal, mange moins, s'agite ou au contraire s'éteint. Et sur les grosses chaleurs, ça peut aller jusqu'au coup de chaud — un vrai danger.</p>" },
    { "type": "header", "content": "Visuel" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "image_alt", "label": "Texte alternatif", "default": "Un chien haletant, couché sur le carrelage à la recherche de fraîcheur" },
    { "type": "select", "id": "image_side", "label": "Côté de l'image", "default": "left",
      "options": [ { "value": "left", "label": "Gauche" }, { "value": "right", "label": "Droite" } ] },
    { "type": "select", "id": "background", "label": "Fond", "default": "default",
      "options": [ { "value": "default", "label": "Sable" }, { "value": "alt", "label": "Sable alterné" }, { "value": "cool", "label": "Glacier clair" } ] }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Signe de chaleur",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icône", "default": "droplet",
          "options": [ { "value": "droplet", "label": "Goutte" }, { "value": "sun", "label": "Soleil" }, { "value": "clock", "label": "Horloge" }, { "value": "paw", "label": "Patte" }, { "value": "heart", "label": "Cœur" } ] },
        { "type": "text", "id": "text", "label": "Texte", "default": "Il halète sans s'arrêter" }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "Le problème",
      "category": "Accueil",
      "blocks": [
        { "type": "point", "settings": { "icon": "droplet", "text": "Il halète sans jamais s'arrêter" } },
        { "type": "point", "settings": { "icon": "sun", "text": "Il cherche sans cesse le sol le plus froid" } },
        { "type": "point", "settings": { "icon": "heart", "text": "Il devient mou, sans entrain" } },
        { "type": "point", "settings": { "icon": "clock", "text": "Il boit beaucoup et dort mal" } }
      ]
    }
  ]
}
{% endschema %}
