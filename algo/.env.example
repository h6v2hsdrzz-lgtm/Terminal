# ============================================================================
# Modèle de variables d'environnement pour le bot (goldsilver-live).
#
# COPIER ce fichier en `.env` puis le REMPLIR avec VOS valeurs :
#     cp .env.example .env
# Le `.env` rempli est ignoré par git (voir .gitignore) — il ne doit JAMAIS
# être commité ni partagé. Ce modèle ne contient que des valeurs VIDES.
#
# Charger dans le shell avant de lancer le bot :
#     set -a; source .env; set +a
#     goldsilver-live run
# ============================================================================

# --- IG Markets (obligatoire) -----------------------------------------------
# Clé API : My IG > Paramètres > API. Identifiant/mot de passe = ceux de connexion.
IG_API_KEY=
IG_IDENTIFIER=
IG_PASSWORD=

# Environnement : "demo" (défaut si vide) ou "live". Laisser sur demo tant que
# le forward test n'est pas concluant. "live" exige aussi les verrous du code.
IG_ENV=

# Compte IG (optionnel) : laisser vide pour utiliser le compte "préféré".
IG_ACCOUNT_ID=

# --- Verrou du mode LIVE (uniquement si un jour vous passez en réel) ---------
# Doit valoir exactement JE-COMPRENDS-ARGENT-REEL pour débloquer le mode live
# (ce n'est PAS un secret, c'est une confirmation volontaire). Laisser vide en paper/demo.
GOLDSILVER_LIVE_ACK=

# --- Alertes Telegram (optionnel) -------------------------------------------
# Vide = notifications désactivées (le bot fonctionne quand même).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
